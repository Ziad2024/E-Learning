{
	"info": {
		"name": "NTI E-Learning API",
		"description": "Full API collection for the NTI E-Learning Platform.\n\n**Setup:**\n1. Register a user\n2. Login → tokens are saved automatically\n3. Use the other endpoints\n\n**Variables:**\n- `baseUrl` → http://localhost:3000\n- `accessToken` → set automatically on login\n- `refreshToken` → set automatically on login\n- `userId`, `courseId`, `lessonId`, `enrollmentId` → set as you go",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "courseId", "value": "" },
		{ "key": "lessonId", "value": "" },
		{ "key": "enrollmentId", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data._id) {",
									"    pm.collectionVariables.set('userId', res.data._id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Omar\",\n    \"lastName\": \"Tarek\",\n    \"email\": \"omar@test.com\",\n    \"password\": \"Test@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Register Admin (change role in DB after)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Admin\",\n    \"lastName\": \"User\",\n    \"email\": \"admin@test.com\",\n    \"password\": \"Admin@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Register Instructor",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Instructor\",\n    \"lastName\": \"One\",\n    \"email\": \"instructor@test.com\",\n    \"password\": \"Inst@1234\",\n    \"role\": \"instructor\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.tokens) {",
									"    pm.collectionVariables.set('accessToken', res.data.tokens.access_token);",
									"    pm.collectionVariables.set('refreshToken', res.data.tokens.refresh_token);",
									"}",
									"if (res.data && res.data.user && res.data.user._id) {",
									"    pm.collectionVariables.set('userId', res.data.user._id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"omar@test.com\",\n    \"password\": \"Test@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Login as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.tokens) {",
									"    pm.collectionVariables.set('accessToken', res.data.tokens.access_token);",
									"    pm.collectionVariables.set('refreshToken', res.data.tokens.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@test.com\",\n    \"password\": \"Admin@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Login as Instructor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.tokens) {",
									"    pm.collectionVariables.set('accessToken', res.data.tokens.access_token);",
									"    pm.collectionVariables.set('refreshToken', res.data.tokens.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"instructor@test.com\",\n    \"password\": \"Inst@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "refreshtoken", "value": "{{refreshToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/auth/refresh-token",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh-token"]
						}
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"omar@test.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/forgot-password",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "forgot-password"]
						}
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"NewPass@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/reset-password/:token",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "reset-password", ":token"],
							"variable": [
								{ "key": "token", "value": "PASTE_RESET_TOKEN_HERE" }
							]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "refreshtoken", "value": "{{refreshToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						}
					}
				}
			]
		},
